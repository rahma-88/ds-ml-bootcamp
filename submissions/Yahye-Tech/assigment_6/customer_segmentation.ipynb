import pandas as pd
import matplotlib.pyplot as plt

from sklearn.preprocessing import StandardScaler
from sklearn.cluster import KMeans, AgglomerativeClustering
from sklearn.metrics import silhouette_score, davies_bouldin_score

# ===========================
# Load Dataset
# ===========================
df = pd.read_csv("raw_wholesale_customers.csv")

print("First 5 Rows")
print(df.head())

print("\nDataset Info")
print(df.info())

# ===========================
# Select Features
# ===========================
features = [
    "Fresh",
    "Milk",
    "Grocery",
    "Frozen",
    "Detergents_Paper",
    "Delicassen"
]

X = df[features].copy()

# ===========================
# IQR Capping
# ===========================
for col in features:

    Q1 = X[col].quantile(0.25)
    Q3 = X[col].quantile(0.75)

    IQR = Q3 - Q1

    lower = Q1 - 1.5 * IQR
    upper = Q3 + 1.5 * IQR

    X[col] = X[col].clip(lower, upper)

print("\nIQR Capping Completed")

# ===========================
# Scale Features
# ===========================
scaler = StandardScaler()
X_scaled = scaler.fit_transform(X)

print("\nScaling Completed")

# ===========================
# Elbow Method
# ===========================
sse = []

for k in range(1, 11):

    model = KMeans(
        n_clusters=k,
        random_state=42,
        n_init="auto"
    )

    model.fit(X_scaled)
    sse.append(model.inertia_)

print("\nSSE Values")
print(sse)

plt.figure(figsize=(7,4))
plt.plot(range(1,11), sse, marker="o")
plt.title("Elbow Method")
plt.xlabel("Number of Clusters")
plt.ylabel("SSE")
plt.grid(True)
plt.show()

# ===========================
# KMeans
# ===========================
kmeans = KMeans(
    n_clusters=5,
    random_state=42,
    n_init="auto"
)

df["KMeans_Cluster"] = kmeans.fit_predict(X_scaled)

print("\nKMeans Finished")

# ===========================
# Evaluation
# ===========================
silhouette = silhouette_score(
    X_scaled,
    df["KMeans_Cluster"]
)

db = davies_bouldin_score(
    X_scaled,
    df["KMeans_Cluster"]
)

print("\nKMeans Silhouette Score:", silhouette)
print("Davies-Bouldin Index:", db)

# ===========================
# Cluster Centers
# ===========================
centers = scaler.inverse_transform(kmeans.cluster_centers_)

centers = pd.DataFrame(
    centers,
    columns=features
)

print("\nCluster Centers")
print(centers)

# ===========================
# Agglomerative Clustering
# ===========================
agg = AgglomerativeClustering(n_clusters=5)

df["Agglomerative_Cluster"] = agg.fit_predict(X_scaled)

agg_score = silhouette_score(
    X_scaled,
    df["Agglomerative_Cluster"]
)

print("\nAgglomerative Silhouette Score:", agg_score)

# ===========================
# Compare
# ===========================
print("\nComparison")
print("KMeans:", silhouette)
print("Agglomerative:", agg_score)

if silhouette > agg_score:
    print("KMeans produced better clusters.")
else:
    print("Agglomerative produced better clusters.")

# ===========================
# Three Customers
# ===========================
print("\nThree Sample Customers")

print(df.loc[
    [0,100,200],
    [
        "Fresh",
        "Milk",
        "Grocery",
        "Frozen",
        "Detergents_Paper",
        "Delicassen",
        "Channel",
        "Region",
        "KMeans_Cluster",
        "Agglomerative_Cluster"
    ]
])

# ===========================
# Save Output
# ===========================
df.to_csv(
    "segmented_wholesale_customers.csv",
    index=False
)

print("\nsegmented_wholesale_customers.csv has been saved successfully.")