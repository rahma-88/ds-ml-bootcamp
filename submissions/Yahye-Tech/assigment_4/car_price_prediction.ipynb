import pandas as pd
import numpy as np

from sklearn.model_selection import train_test_split
from sklearn.linear_model import LinearRegression
from sklearn.ensemble import RandomForestRegressor
from sklearn.metrics import r2_score, mean_absolute_error, mean_squared_error

# ===============================
# STEP 1: Load Dataset
# ===============================
df = pd.read_csv("clean_car_dataset.csv")

print("First Five Rows")
print(df.head())

print("\nShape:", df.shape)

print("\nMissing Values")
print(df.isnull().sum())

# ===============================
# STEP 2: Prepare Features & Target
# ===============================
X = df.drop(columns=["Price", "LogPrice"])
y = df["Price"]

print("\nFeatures")
print(X.columns.tolist())

# ===============================
# STEP 3: Split Dataset
# ===============================
X_train, X_test, y_train, y_test = train_test_split(
    X,
    y,
    test_size=0.20,
    random_state=42
)

print("\nTraining Samples:", len(X_train))
print("Testing Samples:", len(X_test))

# ===============================
# STEP 4: Train Models
# ===============================
linear_model = LinearRegression()
linear_model.fit(X_train, y_train)

rf_model = RandomForestRegressor(
    n_estimators=100,
    random_state=42
)
rf_model.fit(X_train, y_train)

# ===============================
# STEP 5: Evaluation Function
# ===============================
def evaluate(model, X_test, y_test, model_name):

    prediction = model.predict(X_test)

    r2 = r2_score(y_test, prediction)
    mae = mean_absolute_error(y_test, prediction)
    mse = mean_squared_error(y_test, prediction)
    rmse = np.sqrt(mse)

    print("\n==============================")
    print(model_name)
    print("==============================")
    print("R²   :", round(r2,4))
    print("MAE  :", round(mae,2))
    print("MSE  :", round(mse,2))
    print("RMSE :", round(rmse,2))

    return prediction

linear_predictions = evaluate(
    linear_model,
    X_test,
    y_test,
    "Linear Regression Performance"
)

rf_predictions = evaluate(
    rf_model,
    X_test,
    y_test,
    "Random Forest Performance"
)

# ===============================
# STEP 6: Sanity Check
# ===============================
i = 0

sample = X_test.iloc[[i]]

actual = y_test.iloc[i]

linear_pred = linear_model.predict(sample)[0]
rf_pred = rf_model.predict(sample)[0]

print("\n==============================")
print("Sanity Check")
print("==============================")
print("Actual Price            :", actual)
print("Linear Prediction       :", round(linear_pred,2))
print("Random Forest Prediction:", round(rf_pred,2))

# ===============================
# STEP 7: Feature Importance
# ===============================
importance = pd.DataFrame({
    "Feature": X.columns,
    "Importance": rf_model.feature_importances_
})

importance = importance.sort_values(
    by="Importance",
    ascending=False
)

print("\nFeature Importance")
print(importance)

# ===============================
# STEP 8: Prediction Table
# ===============================
results = pd.DataFrame({
    "Actual": y_test.values,
    "Linear Prediction": linear_predictions,
    "Random Forest Prediction": rf_predictions
})

print("\nPrediction Results")
print(results.head())

print("\nNotebook completed successfully!")